APP_ENV=development
DEBUG=false

# Postgres (inside podman-compose network)
DATABASE_URL=postgresql+asyncpg://twain:twain@db:5432/twain

# CORS — patient PWA 7474, doctor PWA 7575
CORS_ORIGINS=http://localhost:7474,http://127.0.0.1:7474,http://localhost:7575,http://127.0.0.1:7575

# JWT — generate a 32+ char secret for prod
JWT_SECRET=change-me-in-prod-at-least-32-chars-long-xxxxxxxx
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Claude (mirrors Stryng Doctor config)
ANTHROPIC_API_KEY=
CLAUDE_CHAT_MODEL=claude-sonnet-4-6
CLAUDE_EFFORT=low

# Qubrid Whisper
QUBRID_API_KEY=
QUBRID_BASE_URL=https://platform.qubrid.com/api/v1/qubridai
QUBRID_WHISPER_MODEL=openai/whisper-large-v3
